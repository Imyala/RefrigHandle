@namespace RefrigHandle.Components.Shared

<Modal Open="@Open" Title="@($"Unlock {TechnicianName}")" OnClose="@HandleCancel">
    <ChildContent>
        <Field Label="Password">
            <input class="text-input" type="password" @bind="password" @bind:event="oninput" />
        </Field>
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="form-error">@errorMessage</div>
        }
    </ChildContent>
    <Footer>
        <AppButton Variant="secondary" OnClick="@HandleCancel">Cancel</AppButton>
        <AppButton OnClick="@HandleSubmit">Unlock</AppButton>
    </Footer>
</Modal>

@code {
    [Parameter] public bool Open { get; set; }
    [Parameter] public string TechnicianName { get; set; } = "";
    [Parameter] public string TechnicianId { get; set; } = "";
    [Parameter] public string? ExpectedHash { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback OnConfirm { get; set; }

    private string password = "";
    private string? errorMessage;

    protected override void OnParametersSet()
    {
        if (!Open)
        {
            password = "";
            errorMessage = null;
        }
    }

    private async Task HandleSubmit()
    {
        if (ExpectedHash is null || Auth.VerifyPassword(TechnicianId, password, ExpectedHash))
        {
            password = "";
            errorMessage = null;
            await OnConfirm.InvokeAsync();
        }
        else
        {
            errorMessage = "Wrong password.";
        }
    }

    private async Task HandleCancel()
    {
        password = "";
        errorMessage = null;
        await OnCancel.InvokeAsync();
    }
}
