@namespace RefrigHandle.Components.Shared

@if (Open)
{
    <div class="modal-backdrop" @onclick="HandleBackdrop">
        <div class="modal" @onclick:stopPropagation>
            @if (!string.IsNullOrEmpty(Title))
            {
                <div class="modal-title">@Title</div>
            }
            <div class="modal-body">@ChildContent</div>
            @if (Footer is not null)
            {
                <div class="modal-footer">@Footer</div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public bool Open { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? Footer { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private async Task HandleBackdrop()
    {
        if (OnClose.HasDelegate) await OnClose.InvokeAsync();
    }
}
