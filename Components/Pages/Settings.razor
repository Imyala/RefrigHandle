@namespace RefrigHandle.Components.Pages
@page "/settings"
@inject AppStateService Store
@inject StorageService Storage
@inject ToastService Toasts
@inject ConfirmService Confirms
@implements IDisposable

<h1 class="page-title">Settings</h1>

<div class="grid">
    <Card Title="Compliance / business">
        <Field Label="Business name">
            <input class="text-input" value="@Store.State.BusinessName"
                   @oninput="@(e => Store.SetBusinessName(e.Value?.ToString() ?? ""))" />
        </Field>
        <Field Label="ARC RTA (Refrigerant Trading Authorisation)" Hint="Frozen on every transaction for audit.">
            <input class="text-input" value="@Store.State.ArcAuthorisationNumber"
                   @oninput="@(e => Store.SetArcAuthorisationNumber(e.Value?.ToString() ?? ""))" />
        </Field>
    </Card>

    <Card Title="Technicians">
        @if (Store.State.Technicians.Count == 0)
        {
            <EmptyState Message="Add a technician profile to start logging compliant transactions." />
        }
        else
        {
            <ul class="list">
                @foreach (var t in Store.State.Technicians)
                {
                    <li class="list-row">
                        <div class="list-row-main">
                            <strong>@t.Name</strong>
                            <span class="list-row-meta"> · RHL @t.ArcLicenceNumber</span>
                            @if (!string.IsNullOrEmpty(t.PasswordHash))
                            {
                                <span class="list-row-meta"> · 🔒 locked</span>
                            }
                        </div>
                        @if (t.Id == Store.State.ActiveTechnicianId)
                        {
                            <Pill Tone="success">Active</Pill>
                        }
                        else
                        {
                            <AppButton Variant="ghost" OnClick="() => RequestActivate(t)">
                                Set active
                            </AppButton>
                        }
                        <AppButton Variant="ghost" OnClick="() => OpenTechEdit(t)">Lock</AppButton>
                        <AppButton Variant="ghost" OnClick="() => RequestDeleteTech(t)">Delete</AppButton>
                    </li>
                }
            </ul>
        }
        <Field Label="New technician name">
            <input class="text-input" @bind="newTechName" />
        </Field>
        <Field Label="ARC RHL (Refrigerant Handling Licence)">
            <input class="text-input" @bind="newTechRhl" />
        </Field>
        <AppButton OnClick="@AddTech">Add technician</AppButton>
    </Card>

    <Card Title="Display">
        <Field Label="Weight unit">
            <select class="select" value="@Store.State.Unit"
                    @onchange="@(e => Store.SetWeightUnit(Enum.Parse<WeightUnit>(e.Value!.ToString()!)))">
                <option value="@WeightUnit.Kg">Kilograms</option>
                <option value="@WeightUnit.Lb">Pounds</option>
            </select>
        </Field>
        <Field Label="Theme">
            <select class="select" value="@Store.State.Theme"
                    @onchange="@(e => Store.SetTheme(Enum.Parse<ThemePreference>(e.Value!.ToString()!)))">
                <option value="@ThemePreference.System">System</option>
                <option value="@ThemePreference.Light">Light</option>
                <option value="@ThemePreference.Dark">Dark</option>
            </select>
        </Field>
        <Field Label="Clock format">
            <select class="select" value="@Store.State.Clock"
                    @onchange="@(e => Store.SetClock(Enum.Parse<ClockFormat>(e.Value!.ToString()!)))">
                <option value="@ClockFormat.TwentyFourHour">24-hour</option>
                <option value="@ClockFormat.TwelveHour">12-hour</option>
            </select>
        </Field>
    </Card>

    <Card Title="Location & timezone">
        <Field Label="Country">
            <input class="text-input" value="@Store.State.Location.Country"
                   @oninput="@(e => UpdateLocation(l => l.Country = e.Value?.ToString() ?? ""))" />
        </Field>
        <Field Label="Region / state">
            <input class="text-input" value="@Store.State.Location.Region"
                   @oninput="@(e => UpdateLocation(l => l.Region = e.Value?.ToString() ?? ""))" />
        </Field>
        <Field Label="City">
            <input class="text-input" value="@Store.State.Location.City"
                   @oninput="@(e => UpdateLocation(l => l.City = e.Value?.ToString() ?? ""))" />
        </Field>
        <Field Label="Timezone (IANA)" Hint="Defaults to Australia/Sydney. e.g. Australia/Brisbane, Pacific/Auckland.">
            <input class="text-input" value="@Store.State.Location.Timezone"
                   @oninput="@(e => UpdateLocation(l => l.Timezone = e.Value?.ToString() ?? ""))" />
        </Field>
    </Card>

    <Card Title="Refrigerants">
        <p>Add a custom refrigerant code that's not in the built-in list. Star a code to pin it to the top of selectors.</p>
        <Field Label="Add custom code (e.g. R513A)">
            <input class="text-input" @bind="newCustomRefrigerant" />
        </Field>
        <AppButton OnClick="@AddCustomRefrigerant">Add</AppButton>

        @if (Store.State.CustomRefrigerants.Count > 0)
        {
            <h3 class="settings-subhead">Custom</h3>
            <ul class="list">
                @foreach (var c in Store.State.CustomRefrigerants)
                {
                    var fav = Store.State.FavoriteRefrigerants.Contains(c, StringComparer.OrdinalIgnoreCase);
                    <li class="list-row">
                        <span class="list-row-main">@c</span>
                        <AppButton Variant="ghost" OnClick="() => Store.ToggleFavoriteRefrigerant(c)">@(fav ? "★" : "☆")</AppButton>
                        <AppButton Variant="ghost" OnClick="() => Store.RemoveCustomRefrigerant(c)">Remove</AppButton>
                    </li>
                }
            </ul>
        }

        <h3 class="settings-subhead">Favourites (built-in)</h3>
        <div class="chip-row">
            @foreach (var c in RefrigerantData.BuiltInTypes)
            {
                var fav = Store.State.FavoriteRefrigerants.Contains(c, StringComparer.OrdinalIgnoreCase);
                <button type="button" class="chip @(fav ? "chip--on" : "")"
                        @onclick="() => Store.ToggleFavoriteRefrigerant(c)">
                    @(fav ? "★ " : "")@c
                </button>
            }
        </div>
    </Card>

    <Card Title="Cylinder presets">
        <p>Save a custom cylinder spec to apply to new bottles in one click.</p>
        <Field Label="Label"><input class="text-input" @bind="presetForm.Label" /></Field>
        <Field Label="Tare (kg)">
            <input class="text-input" type="number" step="0.001" @bind="presetForm.TareKg" />
        </Field>
        <Field Label="Water capacity (L)" Hint="Optional. Drives safe-fill via WC × FR(refrigerant).">
            <input class="text-input" type="number" step="0.1" @bind="presetForm.WaterCapacityKg" />
        </Field>
        <AppButton OnClick="@AddCustomPreset">Add preset</AppButton>

        @if (Store.State.CustomBottlePresets.Count > 0)
        {
            <h3 class="settings-subhead">Custom presets</h3>
            <ul class="list">
                @foreach (var p in Store.State.CustomBottlePresets)
                {
                    var fav = Store.State.FavoriteBottlePresets.Contains(p.Id);
                    <li class="list-row">
                        <span class="list-row-main">@p.Label · tare @p.TareKg kg @(p.WaterCapacityKg is double wc ? $"· {wc} L WC" : "")</span>
                        <AppButton Variant="ghost" OnClick="() => Store.ToggleFavoriteBottlePreset(p.Id)">@(fav ? "★" : "☆")</AppButton>
                        <AppButton Variant="ghost" OnClick="() => Store.RemoveCustomBottlePreset(p.Id)">Remove</AppButton>
                    </li>
                }
            </ul>
        }
    </Card>

    <Card Title="Storage health">
        <p>Local data file: <code>@StorageHealthLabel</code></p>
        @if (Store.LoadStatus == LoadStatus.Corrupted)
        {
            <Pill Tone="danger">Last load was corrupted</Pill>
            @if (!string.IsNullOrEmpty(Store.CorruptedBackupPath))
            {
                <p class="list-row-meta">Backup at: <code>@Store.CorruptedBackupPath</code></p>
            }
            <p>Open the backup in a text editor to recover what you can, then re-import via JSON below.</p>
        }
        else if (Store.LoadStatus == LoadStatus.Empty)
        {
            <Pill Tone="info">Empty (no data yet)</Pill>
        }
        else
        {
            <Pill Tone="success">OK</Pill>
        }
    </Card>

    <Card Title="Backup">
        <p>Export everything (bottles, sites, units, transactions, settings) as a JSON file.</p>
        <AppButton OnClick="@ExportData">Export JSON</AppButton>
        <hr />
        <p>Paste a previously-exported JSON file to restore.</p>
        <textarea class="text-input" rows="6" @bind="importPayload"></textarea>
        <AppButton Variant="secondary" OnClick="@ImportData">Import JSON</AppButton>
    </Card>

    <Card Title="Danger zone">
        <p>Reset wipes bottles, sites, units, and transactions. Keeps technician profiles and settings.</p>
        <AppButton Variant="danger" OnClick="@ResetAll">Reset all data</AppButton>
    </Card>
</div>

<Modal Open="@showTechEdit" Title="Lock technician profile" OnClose="@(() => showTechEdit = false)">
    <ChildContent>
        @if (techEditing is not null)
        {
            <p>Set or clear a password lock for <strong>@techEditing.Name</strong>. The hash is stored locally; the password itself is never saved.</p>
            <Field Label="New password (blank to clear lock)">
                <input class="text-input" type="password" @bind="techPassword" />
            </Field>
        }
    </ChildContent>
    <Footer>
        <AppButton Variant="secondary" OnClick="@(() => showTechEdit = false)">Cancel</AppButton>
        <AppButton OnClick="@SaveTechLock">Save</AppButton>
    </Footer>
</Modal>

<PasswordPromptModal Open="@unlockOpen"
                     TechnicianName="@(unlockTarget?.Name ?? "")"
                     TechnicianId="@(unlockTarget?.Id ?? "")"
                     ExpectedHash="@(unlockTarget?.PasswordHash)"
                     OnCancel="@(() => unlockOpen = false)"
                     OnConfirm="@ConfirmActivateUnlock" />

@code {
    private string newTechName = "";
    private string newTechRhl = "";
    private string newCustomRefrigerant = "";
    private BottlePreset presetForm = new();
    private string importPayload = "";
    private string? exportPayload;

    private bool showTechEdit;
    private Technician? techEditing;
    private string techPassword = "";

    private bool unlockOpen;
    private Technician? unlockTarget;

    protected override void OnInitialized() => Store.OnChange += OnStateChanged;
    public void Dispose() => Store.OnChange -= OnStateChanged;
    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    private string StorageHealthLabel
    {
        get
        {
            try { return Path.Combine(FileSystem.AppDataDirectory, "refrighandle.v1.json"); }
            catch { return "(unavailable)"; }
        }
    }

    private void AddTech()
    {
        if (string.IsNullOrWhiteSpace(newTechName) || string.IsNullOrWhiteSpace(newTechRhl))
        {
            Toasts.Show("Name and RHL are both required.", ToastKind.Error);
            return;
        }
        Store.AddTechnician(new Technician { Name = newTechName, ArcLicenceNumber = newTechRhl });
        Toasts.Show("Technician added", ToastKind.Success);
        newTechName = "";
        newTechRhl = "";
    }

    private async Task RequestDeleteTech(Technician t)
    {
        var ok = await Confirms.AskAsync(
            $"Delete technician {t.Name}? Past transactions keep the frozen audit stamps.",
            "Delete technician", "Delete", "Cancel", danger: true);
        if (!ok) return;
        Store.DeleteTechnician(t.Id);
        Toasts.Show("Technician deleted", ToastKind.Success);
    }

    private void RequestActivate(Technician t)
    {
        if (string.IsNullOrEmpty(t.PasswordHash))
        {
            Store.SetActiveTechnicianId(t.Id);
            Toasts.Show($"Active: {t.Name}", ToastKind.Info);
            return;
        }
        unlockTarget = t;
        unlockOpen = true;
    }

    private void ConfirmActivateUnlock()
    {
        if (unlockTarget is null) return;
        Store.SetActiveTechnicianId(unlockTarget.Id);
        Toasts.Show($"Active: {unlockTarget.Name}", ToastKind.Info);
        unlockOpen = false;
        unlockTarget = null;
    }

    private void OpenTechEdit(Technician t)
    {
        techEditing = t;
        techPassword = "";
        showTechEdit = true;
    }

    private void SaveTechLock()
    {
        if (techEditing is null) return;
        var copy = new Technician
        {
            Id = techEditing.Id,
            Name = techEditing.Name,
            ArcLicenceNumber = techEditing.ArcLicenceNumber,
            CreatedAt = techEditing.CreatedAt,
            PasswordHash = string.IsNullOrEmpty(techPassword)
                ? null
                : Auth.HashPassword(techEditing.Id, techPassword),
        };
        Store.UpdateTechnician(copy);
        Toasts.Show(string.IsNullOrEmpty(techPassword) ? "Lock cleared" : "Lock set", ToastKind.Success);
        showTechEdit = false;
    }

    private void UpdateLocation(Action<LocationSettings> mutate)
    {
        var loc = new LocationSettings
        {
            Country = Store.State.Location.Country,
            Region = Store.State.Location.Region,
            City = Store.State.Location.City,
            Timezone = Store.State.Location.Timezone,
        };
        mutate(loc);
        Store.SetLocation(loc);
    }

    private void AddCustomRefrigerant()
    {
        if (string.IsNullOrWhiteSpace(newCustomRefrigerant))
        {
            Toasts.Show("Enter a refrigerant code.", ToastKind.Error);
            return;
        }
        Store.AddCustomRefrigerant(newCustomRefrigerant);
        newCustomRefrigerant = "";
    }

    private void AddCustomPreset()
    {
        if (string.IsNullOrWhiteSpace(presetForm.Label) || presetForm.TareKg <= 0)
        {
            Toasts.Show("Label and tare are required.", ToastKind.Error);
            return;
        }
        Store.AddCustomBottlePreset(new BottlePreset
        {
            Label = presetForm.Label,
            TareKg = presetForm.TareKg,
            WaterCapacityKg = presetForm.WaterCapacityKg,
            Custom = true,
        });
        Toasts.Show("Preset saved", ToastKind.Success);
        presetForm = new BottlePreset();
    }

    private async Task ExportData()
    {
        try
        {
            exportPayload = Storage.ExportJson(Store.State);
            var path = Path.Combine(FileSystem.CacheDirectory, Storage.ExportFileName());
            await File.WriteAllTextAsync(path, exportPayload);
            await Share.Default.RequestAsync(new ShareFileRequest
            {
                Title = "RefrigHandle backup",
                File = new ShareFile(path),
            });
        }
        catch (Exception ex)
        {
            Toasts.Show($"Export failed: {ex.Message}", ToastKind.Error);
        }
    }

    private async Task ImportData()
    {
        if (string.IsNullOrWhiteSpace(importPayload))
        {
            Toasts.Show("Paste a backup JSON first.", ToastKind.Error);
            return;
        }
        var ok = await Confirms.AskAsync(
            "Importing replaces all current bottles, sites, units, and transactions. Continue?",
            "Import backup", "Replace data", "Cancel", danger: true);
        if (!ok) return;
        try
        {
            var incoming = Storage.ImportJson(importPayload);
            if (incoming is null)
            {
                Toasts.Show("Could not parse the backup.", ToastKind.Error);
                return;
            }
            Store.ImportState(incoming);
            importPayload = "";
            Toasts.Show("Backup imported", ToastKind.Success);
        }
        catch (Exception ex)
        {
            Toasts.Show($"Import failed: {ex.Message}", ToastKind.Error);
        }
    }

    private async Task ResetAll()
    {
        var ok = await Confirms.AskAsync(
            "Reset wipes all bottles, sites, units, and transactions. Technician profiles and settings stay. Continue?",
            "Reset all data", "Reset", "Cancel", danger: true);
        if (!ok) return;
        Store.ResetAll();
        Toasts.Show("All data reset", ToastKind.Success);
    }
}
